{
    "expo": {
        "name": "Budget Pro",
        "slug": "budget-pro",
        "version": "1.0.0",
        "orientation": "portrait",
        "scheme": "budget-pro",
        "userInterfaceStyle": "dark",
        "newArchEnabled": false,
        "splash": {
            "backgroundColor": "#0a0a0f",
            "resizeMode": "contain"
        },
        "ios": {
            "supportsTablet": false,
            "bundleIdentifier": "com.budgetpro.app"
        },
        "android": {
            "adaptiveIcon": {
                "backgroundColor": "#0a0a0f"
            },
            "package": "com.budgetpro.app"
        },
        "web": {
            "bundler": "metro"
        },
        "plugins": [
            "expo-router"
        ],
        "experiments": {
            "typedRoutes": true
        }
    }
}